# BriefScope LOCAL CPU — environment variables
#
# Ollama runs as a bundled container (briefscope_ollama_cpu).
# The model is downloaded automatically on first start.
# Change OLLAMA_MODEL to any model available at hub.ollama.ai

# Model to use (downloaded automatically if not present)
# Recommended CPU models (sorted by resource usage):
#   llama3.2        ~2 GB RAM  — fast, good quality          (default)
#   phi4-mini       ~2.5 GB    — Microsoft, very capable
#   mistral         ~4 GB      — strong reasoning
#   deepseek-r1:7b  ~4 GB      — great for analysis
OLLAMA_MODEL=llama3.2

# Embedding model for document search (RAG). Runs locally in-process via
# sentence-transformers; downloaded automatically on first use. Also selectable
# from the UI. NOTE: changing it invalidates previously indexed documents —
# re-upload them so they are re-embedded with the new model.
# Recommended embedding models (sorted by size):
#   all-MiniLM-L6-v2                          ~80 MB   — fast, English          (default)
#   BAAI/bge-small-en-v1.5                    ~130 MB  — strong English retrieval
#   all-mpnet-base-v2                         ~420 MB  — best quality, English
#   paraphrase-multilingual-MiniLM-L12-v2     ~470 MB  — multilingual (incl. Spanish)
#   intfloat/multilingual-e5-small            ~470 MB  — multilingual retrieval
#   paraphrase-multilingual-mpnet-base-v2     ~1.1 GB  — best multilingual quality
EMBEDDING_MODEL=all-MiniLM-L6-v2

# These are set automatically by docker-compose — do not change:
# ROOT_PATH=/api/briefscope_local_cpu
# LLM_MODE=local
# OLLAMA_HOST=http://briefscope_ollama_cpu:11434
